@page "/alimentos"

@using NutriBalance.Model.Entities
@inject AlimentoController AlimentoController
@inject NavigationManager Navigation
@inject UserSessionService UserSession

<PageTitle>Alimentos</PageTitle>

<h1>Lista de alimentos</h1>

@if (!UserSession.HaySesionActiva())
{
    <div class="alert alert-warning">Debes iniciar sesión.</div>
    <button class="btn btn-primary" @onclick='() => Navigation.NavigateTo("/login")'>
        Ir a login
    </button>
}
else
{
    <div class="mb-3 d-flex gap-2">
        @if (UserSession.EsAdmin())
        {
            <!-- Navigate to create new food (admin only) -->
            <button class="btn btn-success" @onclick='() => Navigation.NavigateTo("/alimentos/nuevo")'>
                Agregar alimento
            </button>
        }

        <!-- Go back to main page -->
        <button class="btn btn-secondary" @onclick='() => Navigation.NavigateTo("/main")'>
            Volver
        </button>
    </div>

    @if (alimentos is null)
    {
        <div class="alert alert-info">Cargando alimentos...</div>
    }
    else if (alimentos.Count == 0)
    {
        <div class="alert alert-warning">No hay alimentos registrados.</div>
    }
    else
    {
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Nombre</th>
                    <th>Calorías</th>
                    <th>Proteínas</th>
                    <th>Carbohidratos</th>
                    <th>Grasas</th>
                    @if (UserSession.EsAdmin())
                    {
                        <th>Acciones</th>
                    }
                </tr>
            </thead>
            <tbody>
                @foreach (var alimento in alimentos)
                {
                    <tr>
                        <td>@alimento.Nombre</td>
                        <td>@alimento.Calorias</td>
                        <td>@alimento.Proteinas</td>
                        <td>@alimento.Carbohidratos</td>
                        <td>@alimento.Grasas</td>

                        @if (UserSession.EsAdmin())
                        {
                            <td>
                                <!-- Navigate to edit page -->
                                <button class="btn btn-primary btn-sm me-2"
                                        @onclick="() => EditarAlimento(alimento.Id)">
                                    Editar
                                </button>

                                <!-- Delete food -->
                                <button class="btn btn-danger btn-sm"
                                        @onclick="() => EliminarAlimento(alimento.Id)">
                                    Eliminar
                                </button>
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    }
}

@code {
    private List<Alimento> alimentos = new();

    /// <summary>
    /// Loads all foods when page initializes
    /// </summary>
    protected override void OnInitialized()
    {
        alimentos = AlimentoController.ObtenerTodos();
    }

    /// <summary>
    /// Navigates to edit page using route parameter
    /// </summary>
    private void EditarAlimento(Guid id)
    {
        Navigation.NavigateTo($"/alimentos/editar/{id}");
    }

    /// <summary>
    /// Deletes a food and refreshes the list
    /// </summary>
    private void EliminarAlimento(Guid id)
    {
        var resultado = AlimentoController.EliminarAlimento(id);

        if (resultado.Exito)
        {
            alimentos = AlimentoController.ObtenerTodos();
        }
    }
}