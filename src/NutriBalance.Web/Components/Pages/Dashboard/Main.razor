@page "/main"
@inject UserSessionService UserSession
@inject NavigationManager Navigation

<PageTitle>Menú principal</PageTitle>

<div class="d-flex justify-content-center align-items-center" style="min-height: 80vh;">
    <div class="card shadow-sm p-4" style="width: 600px;">
        <h1 class="mb-4">Menú principal</h1>

        @if (!UserSession.HaySesionActiva())
        {
            <div class="alert alert-warning">Debes iniciar sesión.</div>
            <button class="btn btn-primary" @onclick='() => Navigation.NavigateTo("/login")'>Ir a login</button>
        }
        else if (UserSession.EsAdmin())
        {
            <div class="alert alert-danger fw-bold">
                Panel de Administrador — @UserSession.UsuarioAutenticado!.Nombre
            </div>
            <div class="d-grid gap-2">
                <button class="btn btn-outline-secondary" @onclick='() => Navigation.NavigateTo("/admin/usuarios")'>Gestión de usuarios</button>
                <button class="btn btn-outline-primary" @onclick='() => Navigation.NavigateTo("/alimentos")'>Alimentos</button>
                <button class="btn btn-outline-info" @onclick='() => Navigation.NavigateTo("/admin/estadisticas")'>Estadísticas globales</button>
                <button class="btn btn-danger" @onclick="CerrarSesion">Cerrar sesión</button>
            </div>
        }
        else
        {
            <div class="alert alert-success">
                Bienvenido, @UserSession.UsuarioAutenticado!.Nombre
            </div>
            <div class="d-grid gap-2">
                <button class="btn btn-outline-primary" @onclick='() => Navigation.NavigateTo("/perfil")'>Mi perfil</button>
                <button class="btn btn-outline-primary" @onclick='() => Navigation.NavigateTo("/resumen")'>Resumen diario</button>
                <button class="btn btn-outline-primary" @onclick='() => Navigation.NavigateTo("/dieta")'>Mi dieta</button>
                <button class="btn btn-outline-primary" @onclick='() => Navigation.NavigateTo("/historico")'>Histórico</button>
                <button class="btn btn-danger" @onclick="CerrarSesion">Cerrar sesión</button>
            </div>
        }
    </div>
</div>

@code {
    private void CerrarSesion()
    {
        UserSession.CerrarSesion();
        Navigation.NavigateTo("/");
    }
}