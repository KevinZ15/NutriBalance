@* Route for the monthly history page *@
@page "/historico"
@inject UserSessionService UserSession
@inject MenuDiarioController MenuDiarioController
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>Histórico</PageTitle>

<h1>Histórico</h1>

@* Redirect unauthenticated users to login *@
@if (!UserSession.HaySesionActiva())
{
    <div class="alert alert-warning">No hay usuario autenticado.</div>
    <button class="btn btn-primary" @onclick="IrLogin">Ir a login</button>
}
else
{
    @* Year and month selectors for filtering the history *@
    <div class="row mb-3">
        <div class="col-md-3">
            <label class="form-label">Año</label>
            <input class="form-control" type="number" @bind="anio" />
        </div>

        <div class="col-md-3">
            <label class="form-label">Mes</label>
            <select class="form-select" @bind="mes">
                @for (int i = 1; i <= 12; i++)
                {
                    <option value="@i">@ObtenerNombreMes(i)</option>
                }
            </select>
        </div>
    </div>

    @* Action buttons for querying, downloading and navigating *@
    <div class="d-flex gap-2 mb-3">
        <button class="btn btn-primary" @onclick="CargarHistorico">Consultar</button>
        @if (resumenMensual.Count > 0)
        {
            <button class="btn btn-success" @onclick="DescargarCSV">Descargar reporte</button>
        }
        <button class="btn btn-secondary" @onclick="Volver">Volver</button>
    </div>

    @* Summary text showing totals for the selected month *@
    <div class="mb-3">
        @resumenTexto
    </div>

    @if (resumenMensual.Count == 0)
    {
        <p>Sin registros para este mes.</p>
    }
    else
    {
        @* Daily calorie history table with goal status per row *@
        <table class="table table-bordered table-striped">
            <thead>
                <tr>
                    <th>Fecha</th>
                    <th>Calorías consumidas</th>
                    <th>Calorías objetivo</th>
                    <th>Diferencia</th>
                    <th>Meta</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in resumenMensual)
                {
                    <tr class="@ObtenerClaseFila(item.Estado)">
                        <td>@item.Fecha.ToString("dd/MM/yyyy")</td>
                        <td>@item.CaloriasConsumidas.ToString("N2")</td>
                        <td>@item.CaloriasObjetivo.ToString("N2")</td>
                        <td>@item.DiferenciaCalorica.ToString("N2")</td>
                        <td>@item.EstadoMeta</td>
                    </tr>
                }
            </tbody>
        </table>
    }
}

@code {
    @* Default to the current year and month *@
    private int anio = DateTime.Today.Year;
    private int mes = DateTime.Today.Month;
    private List<ResumenDiaMes> resumenMensual = [];
    private string resumenTexto = "Sin registros para este mes.";

    @* Loads the history on page initialization *@
    protected override void OnInitialized()
    {
        CargarHistorico();
    }

    @* Fetches the monthly summary and builds the status summary text *@
    private void CargarHistorico()
    {
        if (!UserSession.HaySesionActiva())
            return;

        Usuario usuario = UserSession.UsuarioAutenticado!;
        decimal caloriasObjetivo = NutricionController.CalcularCaloriasObjetivo(usuario);

        resumenMensual = MenuDiarioController.ObtenerResumenMensual(
            usuario.Id,
            anio,
            mes,
            caloriasObjetivo);

        int diasCumplidos = resumenMensual.Count(r => r.Estado == EstadoMetaDiaria.Cumplida);
        int diasExcedidos = resumenMensual.Count(r => r.Estado == EstadoMetaDiaria.Excedida);
        int diasPorDebajo = resumenMensual.Count(r => r.Estado == EstadoMetaDiaria.PorDebajo);
        int totalDias = resumenMensual.Count;

        resumenTexto = totalDias == 0
            ? "Sin registros para este mes."
            : $"Días registrados: {totalDias} | Cumplidos: {diasCumplidos} | Excedidos: {diasExcedidos} | Por debajo: {diasPorDebajo}";
    }

    @* Builds a CSV string from the monthly summary and triggers a browser download *@
    private async Task DescargarCSV()
    {
        var invariant = System.Globalization.CultureInfo.InvariantCulture;
        var sb = new System.Text.StringBuilder();

        sb.AppendLine("sep=;");
        sb.AppendLine("Fecha;Calorias Consumidas;Calorias Objetivo;Diferencia;Meta");

        foreach (var item in resumenMensual)
        {
            string meta = item.Estado switch
            {
                EstadoMetaDiaria.Cumplida => "Cumplida",
                EstadoMetaDiaria.Excedida => "Se excedio",
                _ => "Por debajo"
            };

            sb.AppendLine(string.Join(";",
                item.Fecha.ToString("dd/MM/yyyy"),
                item.CaloriasConsumidas.ToString("F2", invariant),
                item.CaloriasObjetivo.ToString("F2", invariant),
                item.DiferenciaCalorica.ToString("F2", invariant),
                meta
            ));
        }

        string nombreArchivo = $"historico_{ObtenerNombreMes(mes)}_{anio}.csv";
        await JS.InvokeVoidAsync("descargarCSV", nombreArchivo, sb.ToString());
    }

    @* Returns the Spanish month name for the given month number *@
    private static string ObtenerNombreMes(int numeroMes)
    {
        return numeroMes switch
        {
            1 => "Enero",
            2 => "Febrero",
            3 => "Marzo",
            4 => "Abril",
            5 => "Mayo",
            6 => "Junio",
            7 => "Julio",
            8 => "Agosto",
            9 => "Septiembre",
            10 => "Octubre",
            11 => "Noviembre",
            _ => "Diciembre"
        };
    }

    @* Returns the CSS class for a table row based on the daily goal status *@
    private static string ObtenerClaseFila(EstadoMetaDiaria estado)
    {
        return estado switch
        {
            EstadoMetaDiaria.Cumplida => "text-success",
            EstadoMetaDiaria.Excedida => "text-danger",
            _ => "text-warning"
        };
    }

    @* Navigates back to the main menu *@
    private void Volver()
    {
        Navigation.NavigateTo("/main");
    }

    @* Navigates to the login page *@
    private void IrLogin()
    {
        Navigation.NavigateTo("/login");
    }
}